#!/usr/bin/env bash
#
# grandma — the terminal that remembers you.
#
# Usage:
#   grandma                          pick a scope (or describe a new one)
#   grandma <scope> [project] [task] launch a session with that scope's memory
#   grandma init                     first-run setup (memory home, PATH, doctor)
#   grandma save <scope> [project]   distill a finished session into memory
#   grandma review [scope]           review auto-distill proposals
#   grandma ingest [scope] [--root]  catalog a folder of projects into a scope
#   grandma watch <start|status|...> analysis campaigns over your sessions
#   grandma test [scope]             verify the context-integrity invariants
#   grandma doctor                   check dependencies and memory-home health
#   grandma help                     this text
#
# Memory lives in GRANDMA_HOME (default ~/.grandma) — your files, your git repo,
# never this engine's. Scope names that collide with subcommands above are reserved.

set -uo pipefail
ENGINE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

sub="${1:-}"
case "$sub" in
  init|doctor)  shift; exec "$ENGINE/lib/grandma-init.sh" "$sub" "$@" ;;
  save)         shift; exec "$ENGINE/lib/grandma-save.sh" "$@" ;;
  review)       shift; exec "$ENGINE/lib/grandma-review.sh" "$@" ;;
  ingest)       shift; exec "$ENGINE/lib/grandma-ingest.sh" "$@" ;;
  watch)        shift; exec "$ENGINE/lib/grandma-watch.sh" "$@" ;;
  test)         shift; exec "$ENGINE/lib/grandma-test.sh" "$@" ;;
  help|-h|--help) sed -n '3,19p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit 0 ;;
  *)            exec "$ENGINE/lib/grandma-launch.sh" "$@" ;;
esac
